# Copy this file to .env and fill in the values.
# Never commit .env to version control.

SECRET_KEY=replace-with-a-strong-random-secret-key
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ---------------------------------------------------------------------------
# Database engine
# Use 'sqlite' for local development, 'postgres' for production/CI
# ---------------------------------------------------------------------------
DB_ENGINE=sqlite

# ---------------------------------------------------------------------------
# SQLite (DB_ENGINE=sqlite) — no further settings needed
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# PostgreSQL (DB_ENGINE=postgres)
# ---------------------------------------------------------------------------
# DB_ENGINE=postgres
DB_NAME=prostar_paints
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432
